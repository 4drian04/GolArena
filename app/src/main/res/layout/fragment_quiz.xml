<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@drawable/bg_ea_fc">

    <!-- Título principal -->
    <TextView
        android:id="@+id/txtEligeQuiz"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Elige tu Quiz"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:textColor="@color/white"
        android:layout_marginBottom="32dp" />

    <!-- Quiz de Fútbol -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuizFutbol"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground"
        app:strokeWidth="0dp">

        <!-- Fondo con gradiente -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_futbol">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_futbol"
                android:contentDescription="Fútbol"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quiz de Fútbol"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginStart="20dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Quiz de Deportes en general -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardQuizDeportes"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        android:clickable="true"
        android:foreground="?attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_deportes">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_deportes"
                android:contentDescription="Deportes"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quiz de Deportes"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginStart="20dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
