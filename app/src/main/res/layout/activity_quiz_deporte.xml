<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/contenidoQuiz"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Indicador de número de pregunta -->
        <TextView
            android:id="@+id/txtNumeroPregunta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pregunta 1 de 10"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp"
            android:textAlignment="center"/>
        <!-- Título de la pregunta -->
        <TextView
            android:id="@+id/txtPregunta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pregunta"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/onSurface"
            android:layout_marginBottom="24dp"
            android:textAlignment="center"/>

        <!-- Opciones -->
        <LinearLayout
            android:id="@+id/opcionesLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="50dp">

            <!-- Opción ejemplo -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/opcion1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/txtOpcion1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Opcion 1"
                    android:textSize="18sp"
                    android:textColor="@color/onSurface"
                    android:gravity="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/opcion2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/txtOpcion2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Opcion 2"
                    android:textSize="18sp"
                    android:textColor="@color/onSurface"
                    android:gravity="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/opcion3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/txtOpcion3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Opcion 3"
                    android:textSize="18sp"
                    android:textColor="@color/onSurface"
                    android:gravity="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/opcion4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="2dp"
                android:foreground="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/txtOpcion4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Opcion 4"
                    android:textSize="18sp"
                    android:textColor="@color/onSurface"
                    android:gravity="center"
                    android:padding="16dp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Espaciador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
            <LinearLayout
                android:id="@+id/errores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:id="@+id/error1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/error"
                    android:visibility="gone"/>
                <ImageView
                    android:id="@+id/error2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/error"
                    android:visibility="gone"/>
                <ImageView
                    android:id="@+id/error3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/error"
                    android:visibility="gone"/>
            </LinearLayout>
            <TextView
                android:id="@+id/vidaInformativo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="Te quedan 3 vidas"/>
        </LinearLayout>

        <!-- Barra de progreso de pregunta -->
        <LinearLayout
            android:id="@+id/menuProgressBarPreguntaLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">
            <ProgressBar
                android:id="@+id/progresoPregunta"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="50"
                android:progressTint="@color/primary"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:indeterminate="false"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
